# Anthropic — reasoning LLM (required)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI — embeddings for the knowledge layer (required)
OPENAI_API_KEY=

# Market data — at least one of the two is required.
# If both are set, Alpha Vantage is primary and Marketstack is the fallback.
ALPHAVANTAGE_API_KEY=
MARKETSTACK_API_KEY=
